{
  "name": "tradeblocks-mcp",
  "version": "3.0.0-beta.5",
  "description": "MCP server for options trade analysis",
  "author": "David Romeo <davidmromeo@gmail.com>",
  "type": "module",
  "main": "dist/skill-installer.js",
  "bin": {
    "tradeblocks-mcp": "server/index.js"
  },
  "scripts": {
    "build": "tsup && node scripts/copy-provider-assets.mjs && npm run build:http-server && npm run fix-http-import",
    "build:http-server": "esbuild src/http-server.ts --bundle --outfile=server/http-server.js --format=esm --platform=node --target=node18 --packages=external",
    "fix-http-import": "node -e \"const fs=require('fs');const f='server/index.js';let c=fs.readFileSync(f,'utf8');c=c.replace(/\\.\\/http-server-[A-Z0-9]+\\.js/g,'./http-server.js');fs.writeFileSync(f,c);\" && rm -f server/http-server-*.js server/http-server-*.map",
    "dev": "tsup --watch",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "mcpb:pack": "npm run build && node scripts/pack-mcpb.js",
    "pack:beta": "npm run build && npm pack --pack-destination .",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.4.4-r.3",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "csv-parse": "^6.2.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "fzstd": "^0.1.1",
    "jose": "^6.2.3",
    "protobufjs": "^8.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "archiver": "^7.0.1",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "server",
    "dist",
    "agent-skills",
    "manifest.json"
  ],
  "keywords": [
    "mcp",
    "claude",
    "options",
    "trading",
    "backtest"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tradeblocks-org/tradeblocks.git",
    "directory": "packages/mcp-server"
  }
}
